# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used ONLY server-side for account deletion.
# Never expose this to the browser. Keep it secret.
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Gemini ───────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
# If this is not set, the app uses high-quality mock data automatically.
GEMINI_API_KEY=your-key-here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional: override AI model ─────────────────────────────────────────────
# Defaults to gemini-2.0-flash. Use gemini-2.5-flash for higher quality.
# GEMINI_MODEL=gemini-2.5-flash
